{
  "name": "@adametherzlab/relay-scheduler",
  "version": "0.1.0",
  "description": "Cron-style relay/GPIO scheduler for time-based automation",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "bun test",
    "build": "bun build src/index.ts --outdir dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "typescript",
    "bun",
    "typescript",
    "bun",
    "automation",
    "gpio",
    "scheduling",
    "iot"
  ],
  "author": "AdametherzLab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdametherzLab/relay-scheduler.git"
  },
  "homepage": "https://github.com/AdametherzLab/relay-scheduler#readme",
  "bugs": {
    "url": "https://github.com/AdametherzLab/relay-scheduler/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false
